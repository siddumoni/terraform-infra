pipeline {
    agent any

    stages {

        stage('Checkout Code') {
            steps {
                git 'https://github.com/siddumoni/terraform-infra.git'
            }
        }

        stage('Terraform Init') {
            steps {
                dir('Jenkins-Terraform-t2.micro') {
                    sh 'terraform init'
                }
            }
        }

        stage('Terraform Validate') {
            steps {
                dir('project') {
                    sh 'terraform validate'
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                dir('project') {
                    sh 'terraform plan'
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                dir('project') {
                    sh 'terraform apply -auto-approve'
                }
            }
        }

    }
}